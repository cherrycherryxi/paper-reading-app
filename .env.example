# Copy to .env and fill in real values before running `docker compose up -d`.
# .env is gitignored — do not commit it.

# ── Domain (required for HTTPS via Let's Encrypt) ─────────────────────────
DOMAIN=reading.example.com

# ── Public URL used in password-reset emails ──────────────────────────────
APP_PUBLIC_URL=https://reading.example.com

# ── AI API keys (required for chat + OCR features) ────────────────────────
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# ── SMTP for transactional email (optional; without it, reset links log to console) ─
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# ── Admin access for /debug/* endpoints ────────────────────────────────────
ADMIN_TOKEN=

# ── Optional overrides ─────────────────────────────────────────────────────
# Tightens default per-user limits across all endpoints (handy for trial/demo)
# RATE_LIMIT_HOUR=5
# RATE_LIMIT_DAY=20
# SESSION_LIFETIME_DAYS=90
