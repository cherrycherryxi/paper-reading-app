# Copy to .env and fill in real values before running `docker compose up -d`.
# .env is gitignored — do not commit it.

# ── Domain (required for HTTPS via Let's Encrypt) ─────────────────────────
DOMAIN=reading.example.com

# ── Public URL used in password-reset emails ──────────────────────────────
APP_PUBLIC_URL=https://reading.example.com

# ── AI API keys (required for chat + OCR features) ────────────────────────
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# ── Cloud OCR for the fast 快速识别 path (OPT-016, optional) ───────────────
# Baidu 通用文字识别·高精度版. Create an app at
#   https://console.bce.baidu.com/ai/#/ai/ocr/app/list
# (free tier: 1000 calls/month). Without these the fast path falls back to
# local Tesseract automatically. FAST_OCR_ENGINE: auto | cloud | tesseract.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
FAST_OCR_ENGINE=auto
# accurate (default, returns line位置, lets the server drop facing-page noise &
# reflow wrapped lines) | accurate_basic (cheaper free quota, no layout cleanup).
BAIDU_OCR_ENDPOINT=accurate

# ── SMTP for transactional email (optional; without it, reset links log to console) ─
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# ── Admin access for /debug/* endpoints ────────────────────────────────────
ADMIN_TOKEN=
# Comma-separated usernames who see operator-only UI in the app (model
# logs panel etc.). E.g. ADMIN_USERNAMES=alice,bob
ADMIN_USERNAMES=

# ── Object storage (optional; without these, images live on local disk) ────
# Works with any S3-compatible provider:
#   AWS S3:        S3_ENDPOINT="" (default), S3_REGION=us-east-1
#   Cloudflare R2: S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
#   Tencent COS:   S3_ENDPOINT=https://cos.<region>.myqcloud.com
#   Aliyun OSS:    S3_ENDPOINT=https://oss-<region>.aliyuncs.com
# S3_PUBLIC_BASE should be the CDN URL fronting the bucket (e.g. https://cdn.example.com).
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE=

# ── Stripe (for Plus subscription, optional) ──────────────────────────────
# Sign up at https://dashboard.stripe.com, create a Product + recurring Price
# for Plus, then copy the keys here. Without these the upgrade button shows
# a friendly "coming soon" message.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=

# ── Optional overrides ─────────────────────────────────────────────────────
# Tightens default per-user limits across all endpoints (handy for trial/demo)
# RATE_LIMIT_HOUR=5
# RATE_LIMIT_DAY=20
# SESSION_LIFETIME_DAYS=90
