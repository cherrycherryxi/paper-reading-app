.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.field {
  margin-top: 18rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #2d2018;
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.picker,
.textarea {
  width: 100%;
  min-height: 84rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(71, 48, 29, 0.1);
  color: #2d2018;
  box-sizing: border-box;
}

.picker {
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 168rpx;
}

.textarea.tall {
  min-height: 240rpx;
}

button {
  margin-top: 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.chips {
  margin-top: 20rpx;
  white-space: nowrap;
}

.chips-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 6rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #735d4c;
  font-size: 24rpx;
}

.chip-active {
  background: #2d2018;
  color: #fffaf4;
}

.empty {
  margin-top: 20rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  border: 1px dashed rgba(71, 48, 29, 0.16);
  color: #735d4c;
}

.book-card,
.timeline-card,
.quote-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1px solid rgba(71, 48, 29, 0.08);
}

.book-card-head,
.quote-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.status-pill,
.quote-kind,
.quote-badge {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-pill {
  background: rgba(109, 122, 69, 0.12);
  color: #6d7a45;
}

.quote-kind {
  background: rgba(158, 93, 49, 0.12);
  color: #6f3a14;
}

.quote-badge {
  height: fit-content;
  background: rgba(115, 93, 76, 0.12);
  color: #735d4c;
}

.book-title,
.timeline-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.book-meta,
.timeline-copy,
.book-tags {
  margin-top: 8rpx;
  color: #735d4c;
  font-size: 24rpx;
  line-height: 1.6;
}

.progress-track {
  margin-top: 18rpx;
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(71, 48, 29, 0.08);
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #bb7a6c, #9e5d31);
}

.preview-wrap {
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1px solid rgba(71, 48, 29, 0.08);
}

.preview-image,
.quote-image {
  width: 100%;
}

.quote-content {
  margin-top: 18rpx;
  padding: 20rpx;
  border-left: 6rpx solid #9e5d31;
  border-radius: 0 18rpx 18rpx 0;
  background: rgba(255, 255, 255, 0.7);
  white-space: pre-wrap;
  line-height: 1.8;
}
