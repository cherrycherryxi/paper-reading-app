page {
  background: linear-gradient(180deg, #efe4d1 0%, #f7f2e8 55%, #e7dccb 100%);
  color: #2d2018;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 24rpx;
}

.panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 242, 0.9);
  border: 1px solid rgba(71, 48, 29, 0.08);
  box-shadow: 0 16rpx 40rpx rgba(77, 49, 26, 0.08);
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
}

.section-copy {
  margin-top: 8rpx;
  color: #735d4c;
  font-size: 26rpx;
  line-height: 1.6;
}

.button-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.button-row button {
  margin: 0;
}

.primary-button {
  background: linear-gradient(135deg, #9e5d31, #6f3a14);
  color: #fffdf7;
}

.secondary-button {
  background: linear-gradient(135deg, #6d7a45, #556031);
  color: #fcfbf6;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.72);
  color: #2d2018;
  border: 1px solid rgba(71, 48, 29, 0.1);
}

.hero {
  padding: 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, rgba(255, 249, 240, 0.94), rgba(234, 221, 199, 0.9));
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-copy {
  margin-top: 16rpx;
  color: #735d4c;
  font-size: 28rpx;
  line-height: 1.7;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-stat {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
}

.hero-stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
}

.hero-stat-label {
  color: #735d4c;
  font-size: 24rpx;
}
