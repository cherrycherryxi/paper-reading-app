#!/usr/bin/env bash
# pre-push —— push 前在本地跑 CI 同款测试，不绿就拦下。
# 目的：避免"本地只跑了单个测试文件 → 看起来通过 → push 后 CI 才发现别的文件挂了"。
# 紧急绕过：git push --no-verify
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)" || exit 0
cd "$ROOT" || exit 0

FELOG="$(mktemp -t prepush_fe.XXXXXX)"
PYLOG="$(mktemp -t prepush_py.XXXXXX)"
fail=0

echo "──────────────────────────────────────────────"
echo " pre-push 检查（绕过：git push --no-verify）"
echo "──────────────────────────────────────────────"

# [1/2] 前端测试（全量）—— 这次 CI 挂的就是这一类，硬拦
echo "▶ [1/2] node --test tests/frontend/*.test.js"
if node --test tests/frontend/*.test.js > "$FELOG" 2>&1; then
  echo "  ✅ 前端测试通过"
else
  echo "  ❌ 前端测试失败："
  grep -E "not ok|✖|# (tests|pass|fail)|Error|Assert" "$FELOG" | head -n 40 | sed 's/^/     /'
  echo "     （完整输出：$FELOG）"
  fail=1
fi

# [2/2] Python 测试（CI 同款命令）
PYTHON="${ROOT}/.venv/bin/python3"
[ -x "$PYTHON" ] || PYTHON="python3"
echo "▶ [2/2] $PYTHON -m unittest discover -s tests/agent -p '*_test.py'"
if "$PYTHON" -m unittest discover -s tests/agent -p '*_test.py' > "$PYLOG" 2>&1; then
  echo "  ✅ Python 测试通过"
else
  # 仅当唯一的错误是本地缺 mcp 包（reading_mcp_server_tools 导入失败）时，降级为警告。
  if grep -q "No module named 'mcp'" "$PYLOG" \
     && grep -q "FAILED (errors=1)" "$PYLOG" \
     && ! grep -q "failures=" "$PYLOG"; then
    echo "  ⚠️  仅 reading_mcp_server_tools 导入失败 —— CI 装了 requirements.txt，不受影响，已放行。"
  else
    echo "  ❌ Python 测试失败："
    tail -n 40 "$PYLOG" | sed 's/^/     /'
    echo "     （完整输出：$PYLOG）"
    fail=1
  fi
fi

echo "──────────────────────────────────────────────"
if [ "$fail" -ne 0 ]; then
  echo "✋ push 已拦截：先修上面的失败。紧急绕过：git push --no-verify"
  exit 1
fi
echo "✅ 全部检查通过，继续 push"
exit 0
